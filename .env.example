# Gemini / ADK
# Gemini via Vertex AI + Application Default Credentials (NO api key, see Security section)
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
# Sandbox root for uploaded PDFs and extracted assets (absolute path)
PAPER_TO_DECK_SANDBOX=/tmp/paper_to_deck_sandbox
